{
  "categories": [
    {
      "title": "Information gathering tools",
      "description": "Dynamic tools for recon and target discovery",
      "tools": [
        {
          "title": "CloudFlair",
          "description": "Find origin IP behind Cloudflare-protected targets",
          "project_url": "https://github.com/christophetd/CloudFlair",
          "supported_os": ["linux", "macos"],
          "tags": ["osint", "recon", "cloudflare"],
          "install_commands": [
            "git clone https://github.com/christophetd/CloudFlair.git",
            "cd CloudFlair && pip3 install -r requirements.txt"
          ],
          "run_commands": [
            "cd CloudFlair && python3 cloudflair.py -h"
          ]
        },
        {
          "title": "Subfinder",
          "description": "Fast passive subdomain discovery tool",
          "project_url": "https://github.com/projectdiscovery/subfinder",
          "supported_os": ["linux", "macos"],
          "tags": ["recon", "subdomain", "osint"],
          "install_commands": [
            "go install -v github.com/projectdiscovery/subfinder/v2/cmd/subfinder@latest"
          ],
          "run_commands": [
            "subfinder -h"
          ]
        }
      ]
    },
    {
