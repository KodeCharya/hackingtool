    {
      "title": "Anonymously Hiding Tools",
      "description": "Dynamic anonymity and traffic routing tools",
      "tools": [
        {
          "title": "Proxychains-NG Setup",
          "description": "Automates basic proxychains-ng installation and default SOCKS5 configuration",
          "project_url": "https://github.com/rofl0r/proxychains-ng",
          "supported_os": ["linux"],
          "tags": ["anonymity", "network", "proxy"],
          "install_commands": [
            "sudo apt-get install -y proxychains4 || sudo apt-get install -y proxychains-ng",
            "if [ -f /etc/proxychains4.conf ]; then sudo sed -i 's/^socks4.*/socks5 127.0.0.1 9050/' /etc/proxychains4.conf; fi"
          ],
          "run_commands": [
            "proxychains4 -h"
          ]
        }
      ]
    },
